# Example .commitlyignore — copy to .commitlyignore in your repo root.
# Paths matched here are excluded from the diff sent to the AI provider.
# Common dependency lock files are excluded automatically.

# Generated / vendored
dist/
build/
vendor/

# Snapshots and fixtures
*.snap
testdata/

# Minified assets
*.min.js
*.min.css

# Secrets (never send these to a model)
.env
*.pem
